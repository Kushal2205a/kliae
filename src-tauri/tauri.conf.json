{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kliae",
  "version": "0.1.1",
  "identifier": "app.kliae.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Kliae",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2OEJGMDA3N0VGQ0Y5QUQKUldTdCtmeCtCL0NMMW0xRGNWMXRpamhaQ09ZSE1RaHQycis1d21KRXhZaFkzc0JBSGxFSEhUSm0K",
      "endpoints": [
        "https://github.com/Kushal2205a/kliae/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "basicUi"
      }
    }
  }
}